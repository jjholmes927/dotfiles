{
  "permissions": {
    "allow": [
      "Read(**/.claude/**)",
      "Read(~/.claude/**)",
      "Bash(agent-browser)",
      "Bash(agent-browser *)",
      "Bash(gh pr create*)",
      "Bash(diffocop*)",
      "Bash(rubocop*)",
      "Bash(gh api *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "jq '{hookSpecificOutput: {hookEventName: \"PreToolUse\", updatedInput: (.tool_input | if has(\"model\") then . else . + {model: \"opus\"} end)}}'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-alert.sh"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-alert.sh"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-alert.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.sh"
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "guideline-refresher@jjholmes927-claude-skills": true,
    "beam-claude-skills-all@beam-claude-skills": true,
    "beam-claude-skills@beam-claude-skills": true,
    "claude-md-management@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "linear@claude-plugins-official": true
  },
  "effortLevel": "high",
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized"
}
